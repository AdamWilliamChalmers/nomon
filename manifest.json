{
  "manifest_version": 3,
  "name": "Nomon",
  "version": "3.6.5",
  "description": "Metacognitive engagement layer for AI — five signals (Hand-off, Loop, Drift, Mismatch, Depth) that notice when you stop evaluating, not how much you use AI.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://nomon-app.com/*",
    "https://app.lumen.io/*",
    "https://lumen-web-vscp.onrender.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://x.com/*",
        "https://copilot.microsoft.com/*",
        "https://m365.cloud.microsoft/*",
        "https://copilot.cloud.microsoft/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://chat.mistral.ai/*",
        "https://www.meta.ai/*",
        "https://meta.ai/*",
        "https://chat.deepseek.com/*",
        "https://chat.qwen.ai/*",
        "https://www.kimi.com/*",
        "https://kimi.com/*",
        "https://kimi.moonshot.cn/*",
        "https://agent.minimax.io/*",
        "https://chat.minimax.io/*",
        "https://chat.minimaxi.com/*",
        "https://huggingface.co/*",
        "https://www.doubao.com/*",
        "https://doubao.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://x.com/i/grok*",
        "https://copilot.microsoft.com/*",
        "https://m365.cloud.microsoft/chat/*",
        "https://copilot.cloud.microsoft/chat/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://chat.mistral.ai/*",
        "https://www.meta.ai/*",
        "https://meta.ai/*",
        "https://chat.deepseek.com/*",
        "https://chat.qwen.ai/*",
        "https://www.kimi.com/*",
        "https://kimi.com/*",
        "https://kimi.moonshot.cn/*",
        "https://agent.minimax.io/*",
        "https://chat.minimax.io/*",
        "https://chat.minimaxi.com/*",
        "https://huggingface.co/chat/*",
        "https://www.doubao.com/*",
        "https://doubao.com/*"
      ],
      "js": [
        "config.js",
        "adapters/chatgpt.js",
        "adapters/base.js",
        "adapters/claude.js",
        "adapters/gemini.js",
        "adapters/grok.js",
        "adapters/copilot.js",
        "adapters/perplexity.js",
        "adapters/mistral.js",
        "adapters/meta.js",
        "adapters/deepseek.js",
        "adapters/qwen.js",
        "adapters/kimi.js",
        "adapters/minimax.js",
        "adapters/huggingchat.js",
        "adapters/doubao.js",
        "rules.js",
        "net.js",
        "nudges.js",
        "engine.js",
        "goals.js",
        "judge.js",
        "session.js",
        "sparkline.js",
        "widget.js",
        "content.js"
      ],
      "css": ["widget.css"],
      "run_at": "document_idle"
    }
  ]
}
