# --- Phase 1 (launch): trust, not revenue ---
# Required for the dashboard, session ingestion, and weekly digest.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
# Protects /api/digest. Vercel Cron auto-sends `Authorization: Bearer ${CRON_SECRET}`.
CRON_SECRET=
# Published Chrome Web Store listing URL for the landing-page CTAs.
# Falls back to the Web Store homepage until the extension is published.
NEXT_PUBLIC_CHROME_STORE_URL=

# --- Optional: LLM judge (second opinion on subtle cases) ---
# Leave all blank to run rule-based only (free, no external calls).
# Cascade order on error: Anthropic -> OpenAI -> Gemini -> local heuristic.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Phase 2+ (defer until willingness-to-pay is tested): Lumen Deep payments ---
POLAR_CHECKOUT_URL=
NEXT_PUBLIC_POLAR_CHECKOUT_URL=
POLAR_WEBHOOK_SECRET=
