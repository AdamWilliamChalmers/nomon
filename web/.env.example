# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# Without Supabase, /api/session uses an in-memory store (fine for extension testing).

# --- Required for production (optional locally) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
CRON_SECRET=

# --- Landing page CTA ---
NEXT_PUBLIC_CHROME_STORE_URL=

# --- Optional: LLM judge cascade (leave blank for rule-based only) ---
OPENAI_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
OPENAI_JUDGE_MODEL=
XAI_MODEL=
GEMINI_MODEL=

# --- Optional: judge rate limits (defaults in web/lib/rateLimit.ts) ---
JUDGE_IP_PER_MIN=
JUDGE_DAILY_BUDGET=

# --- Optional: Polar Pro checkout ---
POLAR_CHECKOUT_URL=
NEXT_PUBLIC_POLAR_CHECKOUT_URL=
POLAR_WEBHOOK_SECRET=
